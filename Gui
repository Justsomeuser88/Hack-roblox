-- Refresh player list with animation  
local function updatePlayerList()  
    -- Clear existing entries with fade-out  
    for _, child in pairs(scrollFrame:GetChildren()) do  
        if child:IsA("Frame") and child.Name:find("PlayerEntry_") then  
            tweenService:Create(child, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()  
            task.wait(0.05)  
            child:Destroy()  
        end  
    end  

    -- Add new entries with fade-in  
    for _, plr in ipairs(players:GetPlayers()) do  
        if plr ~= player then  
            createPlayerEntry(plr)  
        end  
    end  

    -- Update canvas size  
    local childrenCount = #scrollFrame:GetChildren() - 1  
    scrollFrame.CanvasSize = UDim2.new(0, 0, 0, math.max(0, childrenCount * 58))  
end  

