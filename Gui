function Gui:IsMouseInRect(mousePos, rect)
    return mousePos.X >= rect.Position.X and mousePos.X <= rect.Position.X + rect.Size.X and
           mousePos.Y >= rect.Position.Y and mousePos.Y <= rect.Position.Y + rect.Size.Y
end

function Gui:ToggleMinimize()
    self.Minimized = not self.Minimized
    self.MainWindow.Visible = not self.Minimized
    self.TitleBar.Visible = not self.Minimized
    self.TitleText.Visible = not self.Minimized
    self.CloseButton.Visible = not self.Minimized
    self.CloseText.Visible = not self.Minimized
    self.PlayerListFrame.Visible = not self.Minimized
    for _, item in ipairs(self.PlayerList) do
        if item.Frame then item.Frame.Visible = not self.Minimized end
        if item.Text then item.Text.Visible = not self.Minimized end
        if item.CopyBtn then item.CopyBtn.Visible = not self.Minimized end
        if item.FlingBtn then item.FlingBtn.Visible = not self.Minimized end
        if item.LagBtn then item.LagBtn.Visible = not self.Minimized end
    end
    self.MinimizedButton.Visible = self.Minimized
    self.MinText.Visible = self.Minimized
end

