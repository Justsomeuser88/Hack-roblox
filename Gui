-- ============ SPECTATE SYSTEM ============
local function stopSpectating()
	spectatingPlayer = nil
	spectateScreenGui.Enabled = false
	if Player.Character then
		local hum = Player.Character:FindFirstChildOfClass("Humanoid")
		if hum then Camera.CameraSubject = hum end
	end
end
screenStopBtn.MouseButton1Click:Connect(stopSpectating)

local function startSpectating(target)
	if not target or not target.Character then return end
	local hum = target.Character:FindFirstChildOfClass("Humanoid")
	if hum then 
		spectatingPlayer = target
		Camera.CameraSubject = hum 
		spectateScreenGui.Enabled = true
	end
end

-- ============ UI BUILDER ============
local function buildTVInterface(tvPart)
	if tvGui then tvGui:Destroy() end
	
	tvGui = Instance.new("SurfaceGui")
	tvGui.Name = "VoidTVInterface"
	tvGui.Face = Enum.NormalId.Back
	tvGui.CanvasSize = Vector2.new(800, 600)
	tvGui.Adornee = tvPart
	tvGui.Parent = GuiTarget
	tvGui.AlwaysOnTop = true
	tvGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

	local mainContainer = Instance.new("Frame")
	mainContainer.Size = UDim2.new(1, 0, 1, 0)
	mainContainer.BackgroundColor3 = Color3.fromRGB(5, 5, 8)
	mainContainer.BorderSizePixel = 4
	mainContainer.BorderColor3 = Color3.fromRGB(100, 50, 200)
	mainContainer.Parent = tvGui

	local title = Instance.new("TextLabel")
	title.Size = UDim2.new(1, 0, 0, 60)
	title.BackgroundTransparency = 1
	title.Text = "INFINITE VOID NETWORK"
	title.TextColor3 = Color3.fromRGB(200, 180, 255)
	title.TextScaled = true
	title.Font = Enum.Font.Jura
	title.Parent = mainContainer

	local scroller = Instance.new("ScrollingFrame")
	scroller.Size = UDim2.new(1, -40, 1, -80)
	scroller.Position = UDim2.new(0, 20, 0, 70)
	scroller.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
	scroller.BorderSizePixel = 0
	scroller.ScrollBarThickness = 8
	scroller.Parent = mainContainer

	local layout = Instance.new("UIListLayout")
	layout.Padding = UDim.new(0, 5)
	layout.Parent = scroller

	local function refreshPlayers()
		for _, child in pairs(scroller:GetChildren()) do
			if child:IsA("TextButton") then child:Destroy() end
		end

		local total = 0
		for _, other in pairs(Players:GetPlayers()) do
			if other ~= Player then
				local btn = Instance.new("TextButton")
				btn.Size = UDim2.new(1, -10, 0, 45)
				btn.Text = "  ▶ [ " .. other.Name .. " ]"
				btn.TextXAlignment = Enum.TextXAlignment.Left
				btn.TextSize = 24
				btn.Font = Enum.Font.Code
				btn.TextColor3 = Color3.new(1, 1, 1)
				btn.BackgroundColor3 = Color3.fromRGB(30, 20, 50)
				btn.Parent = scroller
				
				btn.MouseButton1Click:Connect(function()
					startSpectating(other)
				end)
				total = total + 50
			end
		end
		scroller.CanvasSize = UDim2.new(0, 0, 0, total)
	end

	refreshPlayers()
end

-- ============ ENVIRONMENT BUILDER ============
local function buildDimension()
	for _, v in pairs(pocketParts) do
		if v and v.Parent then v:Destroy() end
	end
	pocketParts = {}

	local center = Vector3.new(0, 50000, 0)
	local half = 150 
	local thickness = 10 

	-- The Pitch-Black Shell (Blocks all outside light/skybox)
	for _, data in ipairs({
		{Vector3.new(half*2, thickness, half*2), center - Vector3.new(0, half, 0)}, -- Floor
		{Vector3.new(half*2, thickness, half*2), center + Vector3.new(0, half, 0)}, -- Ceiling
		{Vector3.new(thickness, half*2, half*2), center + Vector3.new(half, 0, 0)}, -- Wall R
		{Vector3.new(thickness, half*2, half*2), center - Vector3.new(half, 0, 0)}, -- Wall L
		{Vector3.new(half*2, half*2, thickness), center + Vector3.new(0, 0, half)}, -- Wall B
		{Vector3.new(half*2, half*2, thickness), center - Vector3.new(0, 0, half)}, -- Wall F
	}) do
		local part = Instance.new("Part")
		part.Anchored = true
		part.CanCollide = true
		part.Size = data[1]
		part.Position = data[2]
		part.Material = Enum.Material.Neon 
		part.Color = Color3.fromRGB(0, 0, 0)
		part.CastShadow = false
		part.Parent = workspace
		table.insert(pocketParts, part)
	end

	-- Rotating Cosmic Core (VFX)
	local vfxCore = Instance.new("Part")
	vfxCore.Anchored = true
	vfxCore.CanCollide = false
	vfxCore.Transparency = 1
	vfxCore.Position = center
	vfxCore.Size = Vector3.new(1, 1, 1)
	vfxCore.Parent = workspace
	table.insert(pocketParts, vfxCore)

	-- Cosmic Dust
	local dust = Instance.new("ParticleEmitter")
	dust.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromRGB(150, 50, 255)),
		ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255, 255, 255)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 100, 255))
	})
	dust.Size = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0.2),
		NumberSequenceKeypoint.new(0.5, 1.5),
		NumberSequenceKeypoint.new(1, 0)
	})
	dust.EmissionDirection = Enum.NormalId.Top
	dust.SpreadAngle = Vector2.new(360, 360)
	dust.Speed = NumberRange.new(5, 15)
	dust.Lifetime = NumberRange.new(10, 20)
	dust.Rate = 600
	dust.Drag = 2
	dust.Rotation = NumberRange.new(0, 360)
	dust.RotSpeed = NumberRange.new(-20, 20)
	dust.Parent = vfxCore

	-- Make the VFX Core Spin to simulate a swirling galaxy
	local spinY = 0
	vfxConnection = RunService.RenderStepped:Connect(function(dt)
		if vfxCore and vfxCore.Parent then
			spinY = spinY + (dt * 10)
			vfxCore.CFrame = CFrame.new(center) * CFrame.Angles(0, math.rad(spinY), 0)
		else
			if vfxConnection then vfxConnection:Disconnect() end
		end
	end)

	-- Deep Space Visual Override
	local cc = Instance.new("ColorCorrectionEffect")
	cc.Brightness = -0.05
	cc.Contrast = 0.4
	cc.Saturation = 0.3
	cc.TintColor = Color3.fromRGB(230, 210, 255)
	cc.Parent = Lighting
	table.insert(voidLightingEffects, cc)
	
	local bloom = Instance.new("BloomEffect")
	bloom.Intensity = 1.5
	bloom.Size = 24
	bloom.Threshold = 1
	bloom.Parent = Lighting
	table.insert(voidLightingEffects, bloom)

	-- TV Screen
	local tvFrame = Instance.new("Part")
	tvFrame.Anchored = true
	tvFrame.CanCollide = true
	tvFrame.Size = Vector3.new(40, 25, 1)
	tvFrame.Position = center + Vector3.new(0, -half + 25, -half + 20) 
	tvFrame.Material = Enum.Material.Neon
	tvFrame.Color = Color3.fromRGB(2, 2, 5)
	tvFrame.Parent = workspace
	table.insert(pocketParts, tvFrame)

	buildTVInterface(tvFrame)
end

-- ============ DOMAIN ANIMATIONS ============
local function doDomainExpansionAnimation()
	isAnimating = true
	local char = Player.Character
	local root = char and char:FindFirstChild("HumanoidRootPart")
	if not root then isAnimating = false return end

	root.Anchored = true

	local flashGui = Instance.new("ScreenGui")
	flashGui.IgnoreGuiInset = true
	flashGui.Parent = GuiTarget

	local flashFrame = Instance.new("Frame")
	flashFrame.Size = UDim2.new(1,0,1,0)
	flashFrame.BackgroundColor3 = Color3.new(0,0,0)
	flashFrame.BackgroundTransparency = 1
	flashFrame.Parent = flashGui

	local domainText = Instance.new("TextLabel")
	domainText.Size = UDim2.new(1,0,0.2,0)
	domainText.Position = UDim2.new(0,0,0.4,0)
	domainText.BackgroundTransparency = 1
	domainText.Text = "領域展開"
	domainText.TextColor3 = Color3.new(1,1,1)
	domainText.TextScaled = true
	domainText.Font = Enum.Font.Oswald
	domainText.TextTransparency = 1
	domainText.Parent = flashFrame
	
	-- Text starts slightly larger to "snap" into place
	local uiScale = Instance.new("UIScale")
	uiScale.Scale = 1.5
	uiScale.Parent = domainText

	local subText = Instance.new("TextLabel")
	subText.Size = UDim2.new(1,0,0.1,0)
	subText.Position = UDim2.new(0,0,0.6,0)
	subText.BackgroundTransparency = 1
	subText.Text = "I N F I N I T E   V O I D"
	subText.TextColor3 = Color3.fromRGB(150, 100, 255)
	subText.TextScaled = true
	subText.Font = Enum.Font.GothamMedium
	subText.TextTransparency = 1
	subText.Parent = flashFrame

	-- 1. Dramatic Camera Zoom
	local origFOV = Camera.FieldOfView
	TweenService:Create(Camera, TweenInfo.new(1, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out), {FieldOfView = 25}):Play()
	
	-- Character Aura
	local aura = Instance.new("ParticleEmitter")
	aura.Color = ColorSequence.new(Color3.fromRGB(50, 0, 100), Color3.fromRGB(200, 150, 255))
	aura.Size = NumberSequence.new(0, 3)
	aura.Rate = 200
	aura.Speed = NumberRange.new(5, 10)
	aura.Parent = root
	
	task.wait(0.8)

	-- 2. The Flash & Text Snap
	aura.Rate = 1000
	aura.Speed = NumberRange.new(20, 50)
	TweenService:Create(flashFrame, TweenInfo.new(0.05), {BackgroundColor3 = Color3.new(1,1,1), BackgroundTransparency = 0}):Play()
	task.wait(0.05)
	TweenService:Create(flashFrame, TweenInfo.new(0.4), {BackgroundColor3 = Color3.new(0,0,0)}):Play()
	
	TweenService:Create(domainText, TweenInfo.new(0.3), {TextTransparency = 0}):Play()
	TweenService:Create(uiScale, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1}):Play()
	TweenService:Create(subText, TweenInfo.new(0.5), {TextTransparency = 0}):Play()

	task.wait(1.5)

	-- 3. Teleport & Build
	origCFrame = root.CFrame
	buildDimension()
	
	root.CFrame = CFrame.new(Vector3.new(0, 50000 - 135, 0), Vector3.new(0, 50000 - 135, -100))
	
	-- 4. Fade out flash cleanly
	TweenService:Create(Camera, TweenInfo.new(0.8, Enum.EasingStyle.Sine), {FieldOfView = origFOV}):Play()
	TweenService:Create(flashFrame, TweenInfo.new(1), {BackgroundTransparency = 1}):Play()
	TweenService:Create(domainText, TweenInfo.new(0.6), {TextTransparency = 1}):Play()
	TweenService:Create(subText, TweenInfo.new(0.6), {TextTransparency = 1}):Play()
	
	task.wait(1)
	
	flashGui:Destroy()
	aura:Destroy()
	root.Anchored = false
	isAnimating = false
end

local function doDomainCloseAnimation()
	isAnimating = true
	local char = Player.Character
	local root = char and char:FindFirstChild("HumanoidRootPart")
	
	local flashGui = Instance.new("ScreenGui")
	flashGui.IgnoreGuiInset = true
	flashGui.Parent = GuiTarget

	local flashFrame = Instance.new("Frame")
	flashFrame.Size = UDim2.new(1,0,1,0)
	flashFrame.BackgroundColor3 = Color3.new(1,1,1) -- White shatter flash
	flashFrame.BackgroundTransparency = 1
	flashFrame.Parent = flashGui

	-- Rapid expand FOV to simulate glass shattering outward
	local origFOV = Camera.FieldOfView
	TweenService:Create(Camera, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {FieldOfView = 120}):Play()
	TweenService:Create(flashFrame, TweenInfo.new(0.3), {BackgroundTransparency = 0}):Play()
	
	task.wait(0.35)
	
	-- CLEANUP EVERYTHING WHILE SCREEN IS WHITE
	stopSpectating()
	if root and origCFrame then root.CFrame = origCFrame end
	if vfxConnection then vfxConnection:Disconnect() end
	
	for _,v in pairs(pocketParts) do
		if v and v.Parent then v:Destroy() end
	end
	for _,v in pairs(voidLightingEffects) do
		if v and v.Parent then v:Destroy() end
	end
	pocketParts = {}
	voidLightingEffects = {}
	if tvGui then tvGui:Destroy(); tvGui = nil end
	
	-- Reset Camera & Fade In
	Camera.FieldOfView = origFOV
	TweenService:Create(flashFrame, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {BackgroundTransparency = 1}):Play()
	
	task.wait(0.8)
	flashGui:Destroy()
	
	pocketOpen = false
	btnText.Text = "⚫ Domain Expansion"
	btnText.Color = Color3.fromRGB(180, 140, 255)
	isAnimating = false
end

-- ============ ENTER / EXIT TRIGGER ============
local function toggleVoid()
	if isAnimating then return end

	if not pocketOpen then
		doDomainExpansionAnimation()
		pocketOpen = true
		btnText.Text = "⚫ Close Domain"
		btnText.Color = Color3.fromRGB(255, 100, 100)
	else
		doDomainCloseAnimation()
	end
end

-- ============ INPUT HANDLING (Fixed Drag Logic) ============
UIS.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		local mousePos = UIS:GetMouseLocation()
		if hitButton(mousePos) then
			isDragging = true
			initialClickPos = mousePos
			dragOffset = btnPos - mousePos
		end
	end
end)

UIS.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		if isDragging then
			local mousePos = UIS:GetMouseLocation()
			-- ONLY trigger if the mouse moved less than 10 pixels total since clicking
			if (mousePos - initialClickPos).Magnitude < 10 then
				toggleVoid()
			end
			isDragging = false
		end
	end
end)

UIS.InputChanged:Connect(function(input)
	if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local mousePos = UIS:GetMouseLocation()
		moveButtonTo(mousePos + dragOffset)
	end
end)

RunService.RenderStepped:Connect(function()
	if not isAnimating then
		bgBox.Visible = true
		btnText.Visible = true
	else
		bgBox.Visible = false
		btnText.Visible = false
	end
end)
