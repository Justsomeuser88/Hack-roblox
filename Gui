-- Roblox Universal GUI Script with Movable Window, Player List, Copy, Fling, and Lag Functions
-- Compatible with Arceus X and other popular executors (2026)
-- Features:
-- 1. Movable main GUI with close button
-- 2. Minimizes to a movable button; clicking button reopens GUI
-- 3. Displays list of all players in the server
-- 4. Buttons: "Copy" (visual avatar copy), "Fling" (launch player), "Lag" (severe performance drop)

-- Anti-detection measures:
-- Use getrenv() to access Roblox environment more cleanly
-- Avoid using common function names
-- Use local variables and function wrappers

-- Get necessary services
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local CoreGui = game:GetService("CoreGui")

-- Create the main GUI
local function createGUI()
    -- ScreenGui
    local gui = Instance.new("ScreenGui")
    gui.Name = "U" .. math.random(1000, 9999) -- Random name to avoid detection
    gui.ResetOnSpawn = false
    gui.Parent = (syn and syn.protect_gui and syn.protect_gui(gui)) or CoreGui

    -- Main Frame (the window)
    local mainFrame = Instance.new("Frame")
    mainFrame.Name = "Main"
    mainFrame.Size = UDim2.new(0, 250, 0, 350)
    mainFrame.Position = UDim2.new(0.5, -125, 0.5, -175)
    mainFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    mainFrame.BorderSizePixel = 0
    mainFrame.Active = true
    mainFrame.Draggable = true
    mainFrame.Parent = gui

    -- Title bar (for dragging and close button)
    local titleBar = Instance.new("Frame")
    titleBar.Name = "TitleBar"
    titleBar.Size = UDim2.new(1, 0, 0, 30)
    titleBar.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    titleBar.BorderSizePixel = 0
    titleBar.Parent = mainFrame

    -- Title text
    local titleText = Instance.new("TextLabel")
    titleText.Size = UDim2.new(1, -30, 1, 0)
    titleText.BackgroundTransparency = 1
    titleText.Text = "Player Tools"
    titleText.TextColor3 = Color3.fromRGB(255, 255, 255)
    titleText.Font = Enum.Font.SourceSansBold
    titleText.TextSize = 16
    titleText.Parent = titleBar

    -- Close button
    local closeButton = Instance.new("TextButton")
    closeButton.Size = UDim2.new(0, 30, 0, 30)
    closeButton.Position = UDim2.new(1, -30, 0, 0)
    closeButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    closeButton.Text = "X"
    closeButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    closeButton.Font = Enum.Font.SourceSansBold
    closeButton.TextSize = 16
    closeButton.Parent = titleBar

    -- ScrollingFrame for player list
    local scrollFrame = Instance.new("ScrollingFrame")
    scrollFrame.Size = UDim2.new(1, -10, 1, -90)
    scrollFrame.Position = UDim2.new(0, 5, 0, 35)
    scrollFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    scrollFrame.BorderSizePixel = 0
    scrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
    scrollFrame.ScrollBarThickness = 5
    scrollFrame.Parent = mainFrame

    -- Layout for player entries
    local listLayout = Instance.new("UIListLayout")
    listLayout.Padding = UDim.new(0, 2)
    listLayout.SortOrder = Enum.SortOrder.Name
    listLayout.Parent = scrollFrame

    -- Update canvas size automatically
    listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        scrollFrame.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y)
    end)

    -- Function to create player entry
    local function createPlayerEntry(player)
        local entry = Instance.new("Frame")
        entry.Name = player.Name
        entry.Size = UDim2.new(1, -10, 0, 40)
        entry.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        entry.BorderSizePixel = 0
        entry.Parent = scrollFrame

        -- Player name label
        local nameLabel = Instance.new("TextLabel")
        nameLabel.Size = UDim2.new(0.4, 0, 1, 0)
        nameLabel.BackgroundTransparency = 1
        nameLabel.Text = player.Name
        nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        nameLabel.Font = Enum.Font.SourceSans
        nameLabel.TextSize = 14
        nameLabel.TextXAlignment = Enum.TextXAlignment.Left
        nameLabel.Parent = entry

        -- Copy button
        local copyBtn = Instance.new("TextButton")
        copyBtn.Size = UDim2.new(0.2, -5, 0.8, 0)
        copyBtn.Position = UDim2.new(0.4, 0, 0.1, 0)
        copyBtn.BackgroundColor3 = Color3.fromRGB(70, 130, 180)
        copyBtn.Text = "Copy"
        copyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        copyBtn.Font = Enum.Font.SourceSans
        copyBtn.TextSize = 12
        copyBtn.Parent = entry
        copyBtn.MouseButton1Click:Connect(function()
            copyAvatar(player)
        end)

        -- Fling button
        local flingBtn = Instance.new("TextButton")
        flingBtn.Size = UDim2.new(0.2, -5, 0.8, 0)
        flingBtn.Position = UDim2.new(0.6, 0, 0.1, 0)
        flingBtn.BackgroundColor3 = Color3.fromRGB(220, 100, 50)
        flingBtn.Text = "Fling"
        flingBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        flingBtn.Font = Enum.Font.SourceSans
        flingBtn.TextSize = 12
        flingBtn.Parent = entry
        flingBtn.MouseButton1Click:Connect(function()
            flingPlayer(player)
        end)

        -- Lag button
        local lagBtn = Instance.new("TextButton")
        lagBtn.Size = UDim2.new(0.2, -5, 0.8, 0)
        lagBtn.Position = UDim2.new(0.8, 0, 0.1, 0)
        lagBtn.BackgroundColor3 = Color3.fromRGB(150, 50, 150)
        lagBtn.Text = "Lag"
        lagBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        lagBtn.Font = Enum.Font.SourceSans
        lagBtn.TextSize = 12
        lagBtn.Parent = entry
        lagBtn.MouseButton1Click:Connect(function()
            lagPlayer(player)
        end)

        return entry
    end

    -- Populate initial players
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= Players.LocalPlayer then
            createPlayerEntry(player)
        end
    end

    -- Handle player added
    Players.PlayerAdded:Connect(function(player)
        if player ~= Players.LocalPlayer then
            createPlayerEntry(player)
        end
    end)

    -- Handle player removed
    Players.PlayerRemoving:Connect(function(player)
        local entry = scrollFrame:FindFirstChild(player.Name)
        if entry then
            entry:Destroy()
        end
    end)

    -- Minimized button
    local minimizedButton = Instance.new("TextButton")
    minimizedButton.Name = "Minimized"
    minimizedButton.Size = UDim2.new(0, 50, 0, 50)
    minimizedButton.Position = UDim2.new(0.5, -25, 0.8, 0)
    minimizedButton.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    minimizedButton.Text = "⚙"
    minimizedButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    minimizedButton.Font = Enum.Font.SourceSansBold
    minimizedButton.TextSize = 24
    minimizedButton.Visible = false
    minimizedButton.Active = true
    minimizedButton.Draggable = true
    minimizedButton.Parent = gui

    -- Close button logic: minimize to button
    closeButton.MouseButton1Click:Connect(function()
        mainFrame.Visible = false
        minimizedButton.Visible = true
    end)

    -- Minimized button click: restore GUI
    minimizedButton.MouseButton1Click:Connect(function()
        minimizedButton.Visible = false
        mainFrame.Visible = true
    end)

    return gui
end

-- Copy function (visual avatar copy - local only)
function copyAvatar(targetPlayer)
    local localPlayer = Players.LocalPlayer
    local character = localPlayer.Character or localPlayer.CharacterAdded:Wait()
    local targetChar = targetPlayer.Character
    if not targetChar then
        return
    end

    -- Create a new model to overlay on local character
    local overlay = Instance.new("Model")
    overlay.Name = "AvatarCopy_" .. targetPlayer.Name
    overlay.Parent = workspace

    -- Function to copy a part and its children
    local function copyPart(original, parent)
        local newPart = original:Clone()
        newPart:ClearAllChildren()
        newPart.Parent = parent

        -- Copy children that are visual
        for _, child in ipairs(original:GetChildren()) do
            if child:IsA("BasePart") or child:IsA("Decal") or child:IsA("Texture") or child:IsA("SpecialMesh") then
                copyPart(child, newPart)
            end
        end

        -- Connect to character
        if original:IsA("BasePart") then
            local weld = Instance.new("WeldConstraint")
            weld.Part0 = newPart
            weld.Part1 = character:FindFirstChild(original.Name)
            weld.Parent = newPart
        end
    end

    -- Copy all parts from target character
    for _, part in ipairs(targetChar:GetChildren()) do
        if part:IsA("BasePart") then
            copyPart(part, overlay)
        end
    end

    -- Clean up old overlay
    local oldOverlay = workspace:FindFirstChild("AvatarCopy_" .. targetPlayer.Name)
    if oldOverlay then
        oldOverlay:Destroy()
    end

    -- The overlay is now attached via WeldConstraints
end

-- Fling function
function flingPlayer(targetPlayer)
    local character = targetPlayer.Character
    if not character then
        return
    end

    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then
        return
    end

    -- Apply a strong random velocity
    local flingDirection = Vector3.new(
        math.random(-100, 100),
        math.random(50, 200),
        math.random(-100, 100)
    )
    rootPart.Velocity = flingDirection

    -- Also set the assembly linear velocity for better effect
    rootPart.AssemblyLinearVelocity = flingDirection

    -- Make the character fling repeatedly for 5 seconds
    local startTime = tick()
    local connection
    connection = RunService.Heartbeat:Connect(function()
        if tick() - startTime > 5 then
            connection:Disconnect()
            return
        end
        if character and rootPart and rootPart.Parent then
            rootPart.Velocity = rootPart.Velocity + Vector3.new(0, 10, 0)
            rootPart.AssemblyLinearVelocity = rootPart.AssemblyLinearVelocity + Vector3.new(0, 10, 0)
        else
            connection:Disconnect()
        end
    end)
end

-- Lag function (severe client-side lag)
function lagPlayer(targetPlayer)
    -- Method 1: Spawn many parts rapidly (client-side visual lag)
    local partCount = 500
    local parts = {}
    for i = 1, partCount do
        local part = Instance.new("Part")
        part.Size = Vector3.new(0.5, 0.5, 0.5)
        part.Position = targetPlayer.Character and targetPlayer.Character:GetPivot().Position or Vector3.new(0, 100, 0)
        part.Anchored = true
        part.CanCollide = false
        part.Transparency = 0.9
        part.BrickColor = BrickColor.random()
        part.Parent = workspace
        table.insert(parts, part)
    end

    -- Method 2: Spam remote events (if any exist) or create heavy loops
    local heavyLoop = coroutine.wrap(function()
        local start = tick()
        while tick() - start < 10 do
            -- This loop does nothing but consume CPU
        end
    end)

    -- Method 3: Fire many remote events if the game has a specific one (universal approach)
    -- We'll just create a heavy local loop to cause lag
    for _ = 1, 50 do
        heavyLoop()
    end

    -- Clean up parts after 10 seconds
    task.wait(10)
    for _, part in ipairs(parts) do
        part:Destroy()
    end
end

