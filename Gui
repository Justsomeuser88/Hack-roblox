--// ENHANCED COPY AVATAR //---------------------------------------------------  
local function copyAvatar(targetPlayer)  
    -- Method 1: Using HumanoidDescription (if accessible)  
    local targetChar = getCharacter(targetPlayer)  
    local targetHumanoid = targetChar:FindFirstChildOfClass("Humanoid")  
    if targetHumanoid then  
        local targetDesc = targetHumanoid:GetAppliedDescription()  
        if targetDesc then  
            local localChar = player.Character  
            if localChar then  
                local localHumanoid = localChar:FindFirstChildOfClass("Humanoid")  
                if localHumanoid then  
                    localHumanoid:ApplyDescription(targetDesc)  
                end  
            end  
        end  
    end  

    -- Method 2: Using Save/Load Player Store (more reliable across games)  
    local success, storeId = pcall(function()  
        return game:GetService("Players"):SavePlayerToStore(targetPlayer.UserId)  
    end)  
    if success and storeId then  
        pcall(function()  
            game:GetService("Players"):LoadPlayerStore(player.UserId, storeId)  
        end)  
    end  

    -- Method 3: Direct character cloning (fallback)  
    if targetChar then  
        local clonedChar = targetChar:Clone()  
        clonedChar.Parent = workspace  
        wait(0.1)  
        local humanoid = clonedChar:FindFirstChildOfClass("Humanoid")  
        if humanoid then  
            local desc = humanoid:GetAppliedDescription()  
            local localHumanoid = player.Character:FindFirstChildOfClass("Humanoid")  
            if localHumanoid then  
                localHumanoid:ApplyDescription(desc)  
            end  
        end  
        clonedChar:Destroy()  
    end  
end  

--// ENHANCED FLING //---------------------------------------------------------  
local activeFlings = {}  
local function flingPlayer(targetPlayer)  
    if activeFlings[targetPlayer] then return end  
    activeFlings[targetPlayer] = true  

    local char = getCharacter(targetPlayer)  
    if not char then activeFlings[targetPlayer] = nil return end  

    local rootPart = char:FindFirstChild("HumanoidRootPart")  
    if not rootPart then activeFlings[targetPlayer] = nil return end  

    -- Store original state for optional restore  
    local originalAnchored = rootPart.Anchored  
    local originalVelocity = rootPart.Velocity  

    -- Method 1: Extreme BodyVelocity + BodyAngularVelocity  
    local linearVel = Instance.new("BodyLinearVelocity")  
    linearVel.MaxForce = Vector3.new(1e9, 1e9, 1e9)  
    linearVel.Velocity = Vector3.new(1e6, 1e6, 1e6)  
    linearVel.Parent = rootPart  

    local angularVel = Instance.new("BodyAngularVelocity")  
    angularVel.MaxTorque = Vector3.new(1e9, 1e9, 1e9)  
    angularVel.AngularVelocity = Vector3.new(1e6, 1e6, 1e6)  
    angularVel.Parent = rootPart  

    -- Method 2: Rapid position pushing  
    local pushLoop = coroutine.wrap(function()  
        while activeFlings[targetPlayer] do  
            if rootPart and rootPart.Parent then  
                -- Apply explosive force by temporarily unanchoring and pushing  
                rootPart.Anchored = false  
                rootPart.Velocity = Vector3.new(  
                    math.random(-5e5, 5e5),  
                    math.random(1e5, 1e6),  
                    math.random(-5e5, 5e5)  
                )  
                rootPart.AssemblyLinearVelocity = Vector3.new(  
                    math.random(-5e5, 5e5),  
                    math.random(1e5, 1e6),  
                    math.random(-5e5, 5e5)  
                )  
            end  
            wait(0.05)  
        end  
    end)  
    pushLoop()  

    -- Auto-stop after 3 seconds (prevents infinite fling)  
    task.delay(3, function()  
        linearVel:Destroy()  
        angularVel:Destroy()  
        if rootPart then  
            rootPart.Anchored = originalAnchored  
            rootPart.Velocity = originalVelocity  
        end  
        activeFlings[targetPlayer] = nil  
    end)  
end  

--// ENHANCED LAG //-----------------------------------------------------------  
local lagActive = {}  
local function lagPlayer(targetPlayer)  
    if lagActive[targetPlayer] then return end  
    lagActive[targetPlayer] = true  

    -- Method 1: RemoteEvent spam (create fake remote if needed)  
    local lagRemote = replicatedStorage:FindFirstChild("_LagRemote_")  
    if not lagRemote then  
        lagRemote = Instance.new("RemoteEvent")  
        lagRemote.Name = "_LagRemote_"  
        lagRemote.Parent = replicatedStorage  
    end  

    local remoteSpam = coroutine.wrap(function()  
        while lagActive[targetPlayer] do  
            pcall(function()  
                -- Fire to target client (if possible)  
                lagRemote:FireClient(targetPlayer, {math.random(1, 1e7)})  
                -- Also fire to server to saturate network  
                lagRemote:FireServer(math.random(1, 1e7))  
            end)  
            wait(0.001)  
        end  
    end)  
    remoteSpam()  

    -- Method 2: Part spam around target  
    local partSpam = coroutine.wrap(function()  
        while lagActive[targetPlayer] do  
            local char = getCharacter(targetPlayer)  
            if char and char:FindFirstChild("HumanoidRootPart") then  
                local root = char.HumanoidRootPart  
                for i = 1, 100 do  
                    if not lagActive[targetPlayer] then break end  
                    local part = Instance.new("Part")  
                    part.Size = Vector3.new(math.random(0.5, 3), math.random(0.5, 3), math.random(0.5, 3))  
                    part.CFrame = root.CFrame * CFrame.new(  
                        math.random(-50, 50),  
                        math.random(-10, 30),  
                        math.random(-50, 50)  
                    )  
                    part.Anchored = true  
                    part.Transparency = 0.8  
                    part.Material = Enum.Material.Neon  
                    part.Color = Color3.fromHSV(math.random(), 1, 1)  
                    part.Parent = workspace  
                    game:GetService("Debris"):AddItem(part, 0.3)  
                end  
            end  
            wait()  
        end  
    end)  
    partSpam()  

    -- Method 3: Constant velocity changes (causes network desync)  
    local velocitySpam = coroutine.wrap(function()  
        while lagActive[targetPlayer] do  
            local char = getCharacter(targetPlayer)  
            if char and char:FindFirstChild("HumanoidRootPart") then  
                char.HumanoidRootPart.Velocity = Vector3.new(  
                    math.random(-1000, 1000),  
                    math.random(-1000, 1000),  
                    math.random(-1000, 1000)  
                )  
                char.HumanoidRootPart.RotVelocity = Vector3.new(  
                    math.random(-500, 500),  
                    math.random(-500, 500),  
                    math.random(-500, 500)  
                )  
            end  
            wait(0.01)  
        end  
    end)  
    velocitySpam()  

    -- Auto-stop after 10 seconds  
    task.delay(10, function()  
        lagActive[targetPlayer] = nil  
        -- Clean up fake remote if created  
        if lagRemote and lagRemote.Parent and not lagRemote:FindFirstChild("_keep_") then  
            lagRemote:Destroy()  
        end  
    end)  
end  

