-- ============ UTILS ============
local function hitButton(pos)
	local min = btnPos - btnSize/2
	local max = btnPos + btnSize/2
	return pos.X >= min.X and pos.X <= max.X and pos.Y >= min.Y and pos.Y <= max.Y
end

local function moveButtonTo(newPos)
	btnPos = newPos
	bgBox.Position = btnPos - btnSize/2
	btnText.Position = btnPos - Vector2.new(0, 12)
end

